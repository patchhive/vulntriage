# ── Optional GitHub Access ────────────────────────────────────────────────────
# Recommended fine-grained PAT:
# Metadata (read), Code scanning alerts (read), Dependabot alerts (read).
# Public reads may work without a token, but security APIs are healthier with one.
# BOT_GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Code scanning reads are healthier with a token.
# Dependabot alert reads require authenticated GitHub access.

# ── Optional app auth ─────────────────────────────────────────────────────────
# VULN_TRIAGE_API_KEY_HASH=
# VULN_TRIAGE_SERVICE_TOKEN_HASH=

# ── Storage ───────────────────────────────────────────────────────────────────
VULN_TRIAGE_DB_PATH=vuln-triage.db
VULN_TRIAGE_PORT=8110

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info
